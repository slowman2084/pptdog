{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ReviewSuggestions",
  "type": "object",
  "required": ["schema_version", "reviewer", "slug", "ts", "suggestions"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "reviewer": { "type": "string", "enum": ["content", "structure", "delivery"] },
    "slug": { "type": "string", "minLength": 1 },
    "ts": { "type": "string", "description": "ISO-8601 timestamp" },
    "suggestions": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "required": ["id", "reviewer", "dimension", "severity", "source_file", "source_lines", "original_content", "options"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z]+-[0-9]{3}$" },
          "reviewer": { "type": "string", "enum": ["content", "structure", "delivery"] },
          "dimension": { "type": "string" },
          "severity": { "type": "string", "enum": ["critical", "major", "minor"] },
          "source_file": { "type": "string" },
          "source_lines": {
            "type": "array",
            "items": { "type": "integer" },
            "minItems": 1,
            "maxItems": 2
          },
          "original_content": { "type": "string" },
          "options": {
            "type": "array",
            "minItems": 3,
            "maxItems": 5,
            "items": {
              "type": "object",
              "required": ["label", "description", "content"],
              "additionalProperties": false,
              "properties": {
                "label": { "type": "string", "enum": ["A","B","C","D","E"] },
                "description": { "type": "string" },
                "content": { "type": "string" },
                "recommended": { "type": "boolean" },
                "reason": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
